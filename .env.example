## --- Environment --- ##
ENV=PRODUCTION
TZ=UTC

## --- Bittensor / subnet --- ##
NETUID=126
NETWORK=finney
WALLET_PATH=/root/.bittensor/wallets
WALLET_NAME=yaroslav-coldkey
HOTKEY=yaroslav-poker44-hotkey

## --- Miner runtime --- ##
AXON_PORT=8092
PM2_NAME=poker44_miner
MINER_SCRIPT=./neurons/miner_hybrid.py
POKER44_MODEL_PATH=./models/hybrid.joblib

## --- Model manifest (required for transparent status) --- ##
# Use your own public GitHub repo — NOT https://github.com/Poker44/Poker44-subnet
POKER44_MODEL_REPO_URL=https://github.com/YOUR_USER/poker44-miner
# Leave empty to auto-detect from `git rev-parse HEAD` in this checkout
POKER44_MODEL_REPO_COMMIT=
POKER44_MODEL_NAME=poker44-hybrid-lgbm-iso
POKER44_MODEL_VERSION=8
POKER44_MODEL_OPEN_SOURCE=true
POKER44_MODEL_INFERENCE_MODE=local

## --- Validator access (optional; empty = validator_permit fallback) --- ##
ALLOWED_VALIDATOR_HOTKEYS=
